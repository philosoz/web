# MiniMax API Configuration
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=abab5.5-chat

# Notion API Configuration (Optional - for future use)
# NOTION_TOKEN=your_notion_token_here
# NOTION_NOTES_DB_ID=your_notes_database_id_here
# NOTION_TECH_DB_ID=your_tech_database_id_here

# Site Configuration
NEXT_PUBLIC_SITE_NAME=张海挺
NEXT_PUBLIC_SITE_URL=https://www.deepself.com

# Resume Upload Configuration
# 选择存储方案: base64 | vercel-blob | aws-s3 | cloudflare-r2
UPLOAD_PROVIDER=base64

# Vercel Blob (如果选择 vercel-blob)
# 需要安装: npm install @vercel/blob
# BLOB_READ_WRITE_TOKEN=your_blob_token

# AWS S3 (如果选择 aws-s3)
# 需要安装: npm install @aws-sdk/client-s3
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_BUCKET_NAME=your_bucket_name

# Cloudflare R2 (如果选择 cloudflare-r2)
# 需要安装: wrangler (Cloudflare Workers)
# R2_BUCKET_ID=your_r2_bucket_id
# R2_PUBLIC_URL=https://your-public-url.r2.dev

# Resume Configuration (Optional - for future use)
# NEXT_PUBLIC_RESUME_URL=https://example.com/resume.pdf
